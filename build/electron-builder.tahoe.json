{
  "appId": "com.openclaw.desktop",
  "productName": "OpenClaw Desktop",
  "artifactName": "${productName}-${version}-tahoe-${arch}.${ext}",
  "icon": "resources/icns/icon_1024.icns",
  "directories": {
    "output": "release-artifacts/mac-arm64-tahoe"
  },
  "extraResources": [
    {
      "from": "resources/node/",
      "to": "node/",
      "filter": [
        "**/*",
        "!**/include/**",
        "!**/share/**",
        "!**/CHANGELOG.md",
        "!**/README.md"
      ]
    },
    {
      "from": "resources/bin/",
      "to": "bin/"
    }
  ],
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "!**/*.map",
    "!**/*.ts",
    "!**/*.tsx",
    "!**/*.md",
    "!**/node_modules/**/*.d.ts",
    "!**/node_modules/**/test/**",
    "!**/node_modules/**/tests/**",
    "!**/node_modules/**/__tests__/**",
    "!**/node_modules/**/docs/**",
    "!**/node_modules/**/example/**",
    "!**/node_modules/**/examples/**"
  ],
  "mac": {
    "icon": "resources/icns/icon_1024.icns",
    "category": "public.app-category.developer-tools",
    "minimumSystemVersion": "26.0",
    "extendInfo": {
      "NSHighResolutionCapable": true
    },
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "x64ArchFiles": "**/*darwin-arm64*"
  },
  "dmg": {
    "title": "${productName} ${version} (Tahoe)"
  }
}

{
  "appId": "com.openclaw.desktop",
  "productName": "OpenClaw Desktop",
  "artifactName": "${productName}-${version}-sequoia-${arch}.${ext}",
  "icon": "resources/icns/icon_1024.icns",
  "directories": {
    "output": "release-artifacts/mac-arm64-sequoia"
  },
  "extraResources": [
    {
      "from": "resources/node/",
      "to": "node/"
    },
    {
      "from": "resources/bin/",
      "to": "bin/"
    }
  ],
  "files": [
    "dist/**/*",
    "electron/**/*",
    "dist-electron/**/*",
    "resources/**/*"
  ],
  "mac": {
    "icon": "resources/icns/icon_1024.icns",
    "category": "public.app-category.developer-tools",
    "minimumSystemVersion": "15.0",
    "extendInfo": {
      "NSHighResolutionCapable": true
    },
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "x64ArchFiles": "**/*darwin-arm64*"
  },
  "dmg": {
    "title": "${productName} ${version} (Sequoia)"
  }
}

{
  "appId": "com.openclaw.desktop",
  "productName": "OpenClaw Desktop",
  "artifactName": "${productName}-${version}-win-${arch}.${ext}",
  "icon": "resources/win/icon_win.ico",
  "directories": {
    "output": "release-artifacts/win"
  },
  "extraResources": [
    {
      "from": "resources/node/",
      "to": "node/",
      "filter": [
        "**/*",
        "!**/include/**",
        "!**/share/**",
        "!**/CHANGELOG.md",
        "!**/README.md"
      ]
    },
    {
      "from": "resources/bin/",
      "to": "bin/"
    }
  ],
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "!**/*.map",
    "!**/*.ts",
    "!**/*.tsx",
    "!**/*.md",
    "!**/node_modules/**/*.d.ts",
    "!**/node_modules/**/test/**",
    "!**/node_modules/**/tests/**",
    "!**/node_modules/**/__tests__/**",
    "!**/node_modules/**/docs/**",
    "!**/node_modules/**/example/**",
    "!**/node_modules/**/examples/**"
  ],
  "mac": null,
  "linux": null,
  "win": {
    "icon": "resources/win/icon_win.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "resources/win/icon_win.ico",
    "uninstallerIcon": "resources/win/icon_win.ico",
    "installerHeaderIcon": "resources/win/icon_win.ico"
  }
}

{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": false,
    "noEmit": false,
    "outDir": "./dist-electron"
  },
  "include": ["electron/**/*", "electron/config/**/*.json", "types/**/*"],
  "exclude": ["electron/**/__tests__/**"]
}
# Git 属性配置文件
# 用于控制 Git 行为和 GitHub Release 源码包导出

# ============================================
# 排除不需要导出到源码包的文件和目录
# ============================================

# 构建输出目录
dist/ export-ignore
dist-electron/ export-ignore
release-artifacts/ export-ignore

# 依赖目录
node_modules/ export-ignore

# Git 相关
.git/ export-ignore
.github/ export-ignore
.gitignore export-ignore
.gitattributes export-ignore

# IDE 和编辑器配置
.vscode/ export-ignore
.idea/ export-ignore
*.swp export-ignore
*.swo export-ignore
.DS_Store export-ignore

# Kiro 配置
.kiro/ export-ignore

# 临时文件和日志
*.log export-ignore
npm-debug.log* export-ignore
yarn-debug.log* export-ignore
yarn-error.log* export-ignore

# 测试覆盖率报告
coverage/ export-ignore
.nyc_output/ export-ignore

# 临时 Markdown 文档（根目录的总结文档）
*_SUMMARY.md export-ignore
*_FINAL.md export-ignore

# 开发和设计文档（可选，如果不想导出）
# docs/ export-ignore
# design/ export-ignore

# ============================================
# 行尾符规范化
# ============================================

# 自动规范化行尾符
* text=auto

# 明确指定文本文件使用 LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.dmg binary
*.zip binary
*.tar.gz binary
